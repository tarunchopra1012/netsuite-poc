{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node10",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@nsp/types": ["./libs/types/src/index.ts"],
      "@nsp/utils": ["./libs/utils/src/index.ts"],
      "@nsp/core": ["./libs/core/src/index.ts"],
      "@nsp/nest-kernel": ["./libs/nest-kernel/src/index.ts"],
      "@nsp/netsuite": ["./libs/netsuite/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
