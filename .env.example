# ─────────────────────────────────────────────────────────────
# NetSuite POC — environment template
# Copy to `.env` and fill in real NetSuite creds for live mode.
# With NO creds the app runs in mock/auto mode and every endpoint
# still returns realistic data (the demo never breaks).
# ─────────────────────────────────────────────────────────────

# Server
PORT=8080

# Data source mode: live | mock | auto  (default: auto)
#   live = always call NetSuite
#   mock = never call NetSuite, serve dummy data through the same mappers
#   auto = try live; on OAuth/SuiteQL failure, fall back to mock automatically
NETSUITE_MODE=auto

# ── NetSuite OAuth (client-credentials, JWT bearer) ──
# Account REST base, e.g. https://1234567-sb1.suitetalk.api.netsuite.com/services/rest
NETSUITE_BASE_URL=
# Token endpoint, e.g. https://1234567-sb1.suitetalk.api.netsuite.com/services/rest/auth/oauth2/v1/token
NETSUITE_TOKEN_URL=
# Integration consumer key (used as JWT `iss`)
NETSUITE_CLIENT_ID=
# Private key (PEM). Use literal \n for newlines when on a single line.
NETSUITE_PRIVATE_KEY=
# Certificate id registered in NetSuite (JWT header `kid`)
NETSUITE_KEY_ID=
# JWT `aud` — usually the token URL
NETSUITE_AUDIENCE=
# Comma-separated scopes
NETSUITE_SCOPES=restlets,rest_webservices
# Signing algorithm: PS256 (default) | RS256 | ES256 | ES512
NETSUITE_JWT_ALGORITHM=PS256
# JWT lifetime in minutes (default 5)
NETSUITE_JWT_EXPIRE_DURATION_IN_MINUTE=5

# ── Redis (token cache) ──
# Inside docker-compose this is redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── Postgres (program sync target) ──
# Inside docker-compose this is postgres://poc:poc@postgres:5432/netsuite_poc
DATABASE_URL=postgres://poc:poc@localhost:5432/netsuite_poc
# Schema for the Program table
DATABASE_SCHEMA=public

# ── Program sync scheduler (optional) ──
# Cron expression; leave empty to disable the scheduled sync.
PROGRAM_SYNC_CRON=
